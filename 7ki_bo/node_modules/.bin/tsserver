else
  export NODE_PATH="/Applications/Personal/ModulaWorks/Projects/7ki/7ki_backend/vue-vben-admin/node_modules/.pnpm/typescript@5.9.3/node_modules/typescript/bin/node_modules:/Applications/Personal/ModulaWorks/Projects/7ki/7ki_backend/vue-vben-admin/node_modules/.pnpm/typescript@5.9.3/node_modules/typescript/node_modules:/Applications/Personal/ModulaWorks/Projects/7ki/7ki_backend/vue-vben-admin/node_modules/.pnpm/typescript@5.9.3/node_modules:/Applications/Personal/ModulaWorks/Projects/7ki/7ki_backend/vue-vben-admin/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../node_modules/.pnpm/typescript@5.9.3/node_modules/typescript/bin/tsserver" "$@"
else
  exec node  "$basedir/../../../../node_modules/.pnpm/typescript@5.9.3/node_modules/typescript/bin/tsserver" "$@"
